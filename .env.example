# =============================================================
# CONFIGURAÇÃO DO PORTAL — copie para .env e preencha
# cp .env.example .env
# =============================================================

# ----------------------------------------------------------
# DOMÍNIO / URL PÚBLICA
# ----------------------------------------------------------
NEXT_PUBLIC_API_URL=https://documentos.suaempresa.com.br/api
FRONTEND_URL=https://documentos.suaempresa.com.br

# ----------------------------------------------------------
# BANCO DE DADOS
# ----------------------------------------------------------
DATABASE_URL=file:/data/db/portal.db

# ----------------------------------------------------------
# SERVIDOR
# ----------------------------------------------------------
PORT=3001

# ----------------------------------------------------------
# SEGURANÇA
# Gere com: openssl rand -hex 32
# ----------------------------------------------------------
JWT_SECRET=GERAR_COM_openssl_rand_-hex_32

# Cifra os segredos da configuração de e-mail (/admin/email) guardados no banco.
# Gere uma única e secreta: openssl rand -hex 32. Rotacionar invalida segredos já salvos.
SETTINGS_ENCRYPTION_KEY=GERAR_COM_openssl_rand_-hex_32

# ----------------------------------------------------------
# D4SIGN
# Sandbox (testes):  https://sandbox.d4sign.com.br/api/v1
# Produção (real):   https://secure.d4sign.com.br/api/v1
# ----------------------------------------------------------
D4SIGN_BASE_URL=https://secure.d4sign.com.br/api/v1
D4SIGN_TOKEN_API=SEU_TOKEN_API
D4SIGN_CRYPT_KEY=SUA_CRYPT_KEY
D4SIGN_DRY_RUN=false
# Obs.: o cofre não é mais global por env — cada departamento define seu próprio
# cofre D4Sign no painel (/admin/users → Departamentos).
# D4SIGN_SIGN_MESSAGE=Olá! Segue documento para assinatura.
# D4SIGN_WEBHOOK_SECRET=

# URL da plataforma D4Sign usada nos links do painel admin (botão "D4Sign")
# Sandbox:  https://sandbox.d4sign.com.br
# Produção: https://secure.d4sign.com.br
NEXT_PUBLIC_D4SIGN_DESK_URL=https://secure.d4sign.com.br

# ----------------------------------------------------------
# E-MAIL — opcional (fallback inicial)
# O envio (SMTP) agora é configurado pela interface em /admin/email e fica
# salvo no banco, com os segredos cifrados. As variáveis abaixo são apenas
# o fallback de remetente usado enquanto a tela não foi configurada.
# ----------------------------------------------------------
EMAIL_FROM_EMAIL=noreply@suaempresa.com.br
EMAIL_FROM_NAME=Portal de Documentos

# ----------------------------------------------------------
# GOTENBERG — conversão de documentos (não alterar)
# ----------------------------------------------------------
GOTENBERG_URL=http://gotenberg:3000

# ----------------------------------------------------------
# BACKUP — obrigatório para backups ficarem no volume Docker
# ----------------------------------------------------------
BACKUP_DIR=/data/backups
